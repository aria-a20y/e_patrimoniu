# Copiază acest fișier în .env și completează valorile.
# Nu adăuga niciodată .env în git!

# Conținutul complet al fișierului JSON de service account Firebase (pe o singură linie)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"e-patrimoniu",...}

# URL-ul aplicației Flutter pe Vercel (pentru CORS)
# Poți adăuga mai multe URL-uri separate prin virgulă
ALLOWED_ORIGIN=https://e-patrimoniu.vercel.app,http://localhost:5000

# Portul serverului (Render setează automat PORT=10000)
PORT=10000
